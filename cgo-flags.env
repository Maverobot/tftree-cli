# Auto-detect ROS 2 include paths from AMENT_PREFIX_PATH.
# Source /opt/ros/<distro>/setup.bash before sourcing this file.
if [ -z "$AMENT_PREFIX_PATH" ]; then
  echo "Warning: AMENT_PREFIX_PATH not set. Source /opt/ros/<distro>/setup.bash first." >&2
fi

_CGO_CFLAGS=""
_CGO_LDFLAGS=""
IFS=: read -ra _ament_paths <<< "$AMENT_PREFIX_PATH"
for _prefix in "${_ament_paths[@]}"; do
  if [ -d "$_prefix/include" ]; then
    for _dir in "$_prefix"/include/*/; do
      _CGO_CFLAGS="$_CGO_CFLAGS -I$_dir"
    done
  fi
  if [ -d "$_prefix/lib" ]; then
    _CGO_LDFLAGS="$_CGO_LDFLAGS -L$_prefix/lib -Wl,-rpath=$_prefix/lib"
  fi
done
export CGO_CFLAGS="$_CGO_CFLAGS"
export CGO_LDFLAGS="$_CGO_LDFLAGS"
unset _CGO_CFLAGS _CGO_LDFLAGS _ament_paths _prefix _dir
